BACKEND_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME_OR_ORG/astralnova-translator-backend:latest
FRONTEND_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME_OR_ORG/astralnova-translator-frontend:latest
BACKEND_PORT=8000
FRONTEND_PORT=3000
DATA_DIR=/app/data
UPLOADS_DIR=/app/uploads
DATABASE_FILE=app.db
INITIAL_PROVIDER_TYPE=openai_compatible
INITIAL_API_BASE_URL=https://api.openai.com/v1
INITIAL_MODEL_NAME=gpt-4o-mini
INITIAL_API_KEY=
INITIAL_CHUNK_SIZE=1500
INITIAL_TRANSLATION_MODE=natural
NEXT_PUBLIC_API_BASE_URL=http://YOUR_NAS_IP_OR_DOMAIN:8000
INTERNAL_API_BASE_URL=http://backend:8000
